{
  "manifest_version": 3,
  "name": "WSSD Cookie Sync",
  "version": "1.0.0",
  "description": "Sincroniza tu sesión de Instagram, Facebook, TikTok y YouTube con WSSD automáticamente.",
  "permissions": [
    "cookies",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://*.facebook.com/*",
    "https://*.tiktok.com/*",
    "https://*.youtube.com/*",
    "https://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WSSD Cookie Sync"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
